  <div class="topbar">
    <div class="topbar-brand">
      <button class="sidebar-toggle-btn" id="sidebarToggleBtn" onclick="toggleSidebar()" title="Toggle sidebar (&#8984;B)" aria-label="Toggle sidebar"><span class="sidebar-toggle-mark">#</span></button>
      <div class="topbar-logo">PRAGMA<span>// Workbench</span></div>
    </div>

    <div class="target-selector" id="targetSelector">
      <button class="target-selector-copy target-selector-copy-ip" id="targetSelectorCopy" title="Copy IP" onclick="copyActiveTargetIP()" aria-label="Copy active target IP">
        <span class="target-copy-text" id="targetCopyIpText">—</span>
      </button>
      <button class="target-selector-main" id="targetSelectorMain" onclick="openTargetsPanel()" title="Open targets">
        <div class="target-sel-dot" id="targetSelDot"></div>
        <span class="target-sel-label target-sel-label-main" id="targetSelLabel">No target</span>
        <span class="target-sel-arrow" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </span>
      </button>
      <button class="target-selector-copy target-selector-copy-domain" id="targetSelectorCopyDomain" title="Copy domain" onclick="copyActiveTargetDomain()" aria-label="Copy active target domain">
        <span class="target-copy-text" id="targetCopyDomainText">—</span>
      </button>
    </div>

    <div class="utility-topbar-group">
      <div class="svc-topbar-wrap" id="svcTopbarWrap">
        <button class="svc-topbar-btn utility-topbar-segment utility-topbar-segment-left" id="svcTopbarBtn" onclick="toggleSvcPopover()" title="Port/Service Quick-Log (Ctrl+L)">
          <span style="display:flex;align-items:center;gap:5px"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,17 10,11 4,5"/><line x1="12" y1="19" x2="20" y2="19"/></svg> Log</span>
          <span class="svc-topbar-btn-count" id="svcTopbarCount"></span>
        </button>
        <div class="svc-popover" id="svcPopover">
          <div class="svc-popover-hdr">
            <span class="svc-popover-title">&#9889; Quick Log</span>
            <span class="svc-popover-session-label" id="svcSessionLabel"></span>
            <div class="svc-tabs">
              <button class="svc-tab active" id="svcTabPorts" onclick="switchSvcTab('ports')">Ports <span class="svc-tab-count" id="svcTabCountPorts"></span></button>
              <button class="svc-tab" id="svcTabPaths" onclick="switchSvcTab('paths')">Paths <span class="svc-tab-count" id="svcTabCountPaths"></span></button>
              <button class="svc-tab" id="svcTabLoot" onclick="switchSvcTab('loot')">Loot <span class="svc-tab-count" id="svcTabCountLoot"></span></button>
            </div>
            <button class="svc-clear-btn" id="svcClearBtn" onclick="clearActiveQuickLog()" disabled>Clear All</button>
            <button class="icon-btn" onclick="closeSvcPopover()" style="font-size:14px;padding:2px 6px">&times;</button>
          </div>

          <div class="svc-popover-body" id="svcPanelPorts">
            <div class="svc-hint">Format: <strong style="color:var(--text2)">port/proto service version notes</strong> &mdash; e.g. <code style="color:var(--green);font-size:12px">445/tcp smb</code> &nbsp; <code style="color:var(--green);font-size:12px">8080 http nginx 1.18</code></div>
            <div class="svc-quick-input-row">
              <input class="svc-quick-input" id="svcQuickInput" type="text"
                placeholder="80/tcp http apache 2.4.49&hellip;"
                autocomplete="off" spellcheck="false"
                onkeydown="if(event.key==='Enter')addServiceLog()">
              <button class="svc-quick-add-btn" onclick="addServiceLog()">+ Add</button>
              <button class="svc-quick-add-btn" style="background:var(--bg3);color:var(--btn-color);border-color:var(--border)" onclick="toggleToolPaste('ports')" id="portPasteToggle" title="Paste tool output"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,17 10,11 4,5"/><line x1="12" y1="19" x2="20" y2="19"/></svg> Import</button>
            </div>
            <div id="portPastePanel" style="display:none;flex-direction:column;gap:6px;margin-top:6px">
              <div class="svc-hint" style="margin-bottom:2px">Paste output from: <strong style="color:var(--text2)">nmap &middot; rustscan &middot; masscan</strong></div>
              <textarea id="portPasteInput" placeholder="Paste tool output here&hellip;" spellcheck="false"
                style="width:100%;height:110px;background:var(--bg);border:1px solid var(--border);border-radius:6px;
                       color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:8px 10px;
                       outline:none;resize:vertical;box-sizing:border-box;line-height:1.5"></textarea>
              <div id="portParsePreview" style="display:none"></div>
              <div style="display:flex;gap:6px">
                <button class="svc-quick-add-btn" onclick="parseAndPreviewPorts()" style="flex:1">&#9889; Parse</button>
                <button class="svc-quick-add-btn" onclick="commitPortParse()" id="portCommitBtn"
                  style="flex:1;display:none;background:var(--accent);border-color:var(--accent);color:#fff">+ Add</button>
                <button class="svc-quick-add-btn" onclick="toggleToolPaste('ports')"
                  style="background:var(--bg3);color:var(--muted);border-color:var(--border)">Cancel</button>
              </div>
            </div>
            <div class="svc-popover-table-wrap">
              <div id="svcLogTable"></div>
            </div>
          </div>

          <div class="svc-popover-body" id="svcPanelPaths" style="display:none">
            <div class="svc-hint">Log web paths from directory/vhost enumeration.</div>
            <div class="svc-quick-input-row">
              <input class="svc-quick-input" id="pathQuickInput" type="text"
                placeholder="/admin  or  200 /login.php"
                autocomplete="off" spellcheck="false"
                onkeydown="if(event.key==='Enter')addPathLog()">
              <button class="svc-quick-add-btn" onclick="addPathLog()">+ Add</button>
              <button class="svc-quick-add-btn" style="background:var(--bg3);color:var(--btn-color);border-color:var(--border)" onclick="toggleToolPaste('paths')" id="pathPasteToggle" title="Paste tool output"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,17 10,11 4,5"/><line x1="12" y1="19" x2="20" y2="19"/></svg> Import</button>
            </div>
            <div id="pathPastePanel" style="display:none;flex-direction:column;gap:6px;margin-top:6px">
              <div class="svc-hint" style="margin-bottom:2px">Paste output from: <strong style="color:var(--text2)">gobuster &middot; ffuf &middot; dirbuster</strong></div>
              <textarea id="pathPasteInput" placeholder="Paste tool output here&hellip;" spellcheck="false"
                style="width:100%;height:110px;background:var(--bg);border:1px solid var(--border);border-radius:6px;
                       color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:8px 10px;
                       outline:none;resize:vertical;box-sizing:border-box;line-height:1.5"></textarea>
              <div id="pathParsePreview" style="display:none"></div>
              <div style="display:flex;gap:6px">
                <button class="svc-quick-add-btn" onclick="parseAndPreviewPaths()" style="flex:1">&#9889; Parse</button>
                <button class="svc-quick-add-btn" onclick="commitPathParse()" id="pathCommitBtn"
                  style="flex:1;display:none;background:var(--accent);border-color:var(--accent);color:#fff">+ Add</button>
                <button class="svc-quick-add-btn" onclick="toggleToolPaste('paths')"
                  style="background:var(--bg3);color:var(--muted);border-color:var(--border)">Cancel</button>
              </div>
            </div>
            <div class="svc-popover-table-wrap">
              <div id="pathLogTable"></div>
            </div>
          </div>

          <div class="svc-popover-body" id="svcPanelLoot" style="display:none">
            <div class="svc-hint">Log credentials, hashes, tokens and other loot found during the engagement.</div>
            <div style="display:flex;gap:5px;margin-bottom:8px;flex-wrap:wrap">
              <span style="font-family:'Inter',sans-serif;font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;align-self:center;flex-shrink:0">Type</span>
              <button class="loot-type-btn active" data-ltype="cleartext" onclick="setLootType(this,'cleartext')">Cleartext</button>
              <button class="loot-type-btn" data-ltype="hash" onclick="setLootType(this,'hash')">Hash</button>
              <button class="loot-type-btn" data-ltype="token" onclick="setLootType(this,'token')">Token</button>
              <button class="loot-type-btn" data-ltype="key" onclick="setLootType(this,'key')">Key</button>
              <button class="loot-type-btn" data-ltype="other" onclick="setLootType(this,'other')">Other</button>
            </div>
            <div class="svc-quick-input-row" style="margin-bottom:6px">
              <input class="svc-quick-input" id="lootCredInput" type="text"
                placeholder="username:password  /  hash  /  token  /  key&hellip;"
                autocomplete="off" spellcheck="false"
                onkeydown="if(event.key==='Enter')document.getElementById('lootHostInput').focus()">
              <button class="svc-quick-add-btn" style="background:var(--bg3);color:var(--btn-color);border-color:var(--border)" onclick="toggleToolPaste('loot')" id="lootPasteToggle" title="Paste user/password list"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,17 10,11 4,5"/><line x1="12" y1="19" x2="20" y2="19"/></svg> Import</button>
            </div>
            <div id="lootPastePanel" style="display:none;flex-direction:column;gap:6px;margin-top:0;margin-bottom:6px">
              <div class="svc-hint" style="margin-bottom:2px">Paste one credential per line: <strong style="color:var(--text2)">username:password</strong> or just <strong style="color:var(--text2)">username</strong></div>
              <textarea id="lootPasteInput" placeholder="admin:Summer2024!&#10;svc-backup&#10;jdoe:Password123" spellcheck="false"
                style="width:100%;height:110px;background:var(--bg);border:1px solid var(--border);border-radius:6px;
                       color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:8px 10px;
                       outline:none;resize:vertical;box-sizing:border-box;line-height:1.5"></textarea>
              <div id="lootParsePreview" style="display:none"></div>
              <div style="display:flex;gap:6px">
                <button class="svc-quick-add-btn" onclick="parseAndPreviewLoot()" style="flex:1">&#9889; Parse</button>
                <button class="svc-quick-add-btn" onclick="commitLootParse()" id="lootCommitBtn"
                  style="flex:1;display:none;background:var(--accent);border-color:var(--accent);color:#fff">+ Add</button>
                <button class="svc-quick-add-btn" onclick="toggleToolPaste('loot')"
                  style="background:var(--bg3);color:var(--muted);border-color:var(--border)">Cancel</button>
              </div>
            </div>
            <div class="svc-quick-input-row">
              <input class="svc-quick-input" id="lootHostInput" type="text"
                placeholder="Host / IP"
                autocomplete="off" spellcheck="false" style="flex:0 0 150px"
                onkeydown="if(event.key==='Enter')document.getElementById('lootNoteInput').focus()">
              <input class="svc-quick-input" id="lootNoteInput" type="text"
                placeholder="Context &mdash; SMB share, /etc/shadow, .env&hellip;"
                autocomplete="off" spellcheck="false"
                onkeydown="if(event.key==='Enter')addLootEntry()">
              <button class="svc-quick-add-btn" onclick="addLootEntry()">+ Add</button>
            </div>
            <div class="svc-popover-table-wrap">
              <div id="lootLogTable"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="todo-topbar-wrap" id="todoTopbarWrap">
        <button class="svc-topbar-btn todo-topbar-btn utility-topbar-segment utility-topbar-segment-right" id="todoTopbarBtn" onclick="toggleTodoPopover()" title="Session TODOs">
          <span style="display:flex;align-items:center;gap:5px"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/><path d="M9 7H7"/><path d="M9 12H7"/><path d="M9 17H7"/></svg> TODO</span>
          <span class="todo-topbar-btn-count" id="todoTopbarCount"></span>
        </button>
        <div class="todo-popover" id="todoPopover">
          <div class="todo-popover-hdr">
            <span class="todo-popover-title">TODO</span>
            <span class="svc-popover-session-label" id="todoSessionLabel"></span>
            <button class="todo-clear-btn" id="todoClearBtn" onclick="clearCompletedTodos()" disabled>Clear Done</button>
            <button class="icon-btn" onclick="closeTodoPopover()" title="Close TODO panel" style="font-size:14px;padding:2px 6px">&times;</button>
          </div>
          <div class="todo-popover-body">
            <div class="svc-hint">Keep short next-step tasks per session. Completed items stay saved until you clear them.</div>
            <div class="svc-quick-input-row" style="margin-bottom:10px">
              <input class="svc-quick-input" id="todoQuickInput" type="text"
                placeholder="Enumerate SMB shares, retry WinRM creds, check web admin panel…"
                autocomplete="off" spellcheck="false"
                onkeydown="if(event.key==='Enter')addTodoEntry()">
              <button class="svc-quick-add-btn" onclick="addTodoEntry()">+ Add</button>
            </div>
            <div class="todo-list-wrap">
              <div id="todoList"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <button class="cmd-trigger" onclick="openCmd()" title="&#8984;K">
      <span class="cmd-trigger-icon">&#8984;</span>
      <span class="cmd-trigger-text">Quick open, search anything&hellip;</span>
      <span class="cmd-trigger-kbd">&#8984;K</span>
    </button>

    <button class="tb-btn" onclick="openShortcutsModal()" title="Keyboard shortcuts">?</button>

    <div class="topbar-actions">
      <div class="theme-toggle" id="themeBtn" role="group" aria-label="Theme selector">
        <button class="theme-toggle-btn" id="themeLightBtn" onclick="setTheme('light')" title="Use light theme" aria-pressed="false">Light</button>
        <button class="theme-toggle-btn" id="themeDarkBtn" onclick="setTheme('dark')" title="Use dark theme" aria-pressed="false">Dark</button>
      </div>
    </div>
  </div>
