    </div>
    <div class="welcome-session-body">
      <div class="welcome-session-intro">
        <div class="welcome-session-kicker">PRAGMA <span>// Workbench</span></div>
        <div class="welcome-session-title">Choose a session to continue</div>
        <div class="welcome-session-copy">Resume an existing workspace or create a new session before you start working.</div>
      </div>
      <div class="welcome-session-layout">
        <div class="welcome-session-panel">
          <div class="welcome-session-panel-hdr">Existing Sessions</div>
          <div class="welcome-session-list" id="welcomeSessionList"></div>
        </div>
        <div class="welcome-session-panel welcome-session-create-panel">
          <div class="welcome-session-panel-hdr">Create Session</div>
          <div class="session-field">
            <label>Session codename</label>
            <input id="welcomeSessionName" type="text" placeholder="e.g. OP-BLACKSITE, CLIENT-XYZ…" autocomplete="off" onkeydown="if(event.key==='Enter')createSession('welcome')">
          </div>
          <div class="session-field">
            <label>Session domain (optional)</label>
            <input id="welcomeSessionDomain" type="text" placeholder="e.g. corp.local" autocomplete="off" spellcheck="false" onkeydown="if(event.key==='Enter')createSession('welcome')">
            <div class="session-field-hint">Used as the default <code>DOMAIN</code> context for the session when a target-specific domain is not set.</div>
          </div>
          <div class="session-field">
            <label>Initial target (optional)</label>
            <div class="session-inline-field welcome-session-inline-field">
              <input id="welcomeSessionTargetIP" type="text" placeholder="IP / Host" autocomplete="off" spellcheck="false" onkeydown="if(event.key==='Enter')createSession('welcome')">
              <input id="welcomeSessionTargetDomain" type="text" placeholder="Target domain-name" autocomplete="off" spellcheck="false" onkeydown="if(event.key==='Enter')createSession('welcome')">
              <input id="welcomeSessionTargetLabel" type="text" placeholder="Label" autocomplete="off" spellcheck="false" onkeydown="if(event.key==='Enter')createSession('welcome')">
            </div>
            <div class="session-field-hint">Optional. If filled, the session opens with this target already added and selected.</div>
          </div>
          <div class="welcome-session-actions">
            <button class="session-btn primary" type="button" onclick="createSession('welcome')">+ Create Session</button>
            <button class="session-btn secondary" type="button" onclick="document.getElementById('welcomeImportSessionFile').click()">&#11014; Import .session</button>
            <input type="file" id="welcomeImportSessionFile" accept=".session" data-source="welcome" data-feedback-id="welcomeImportFeedback" style="display:none" onchange="importSession(event)">
          </div>
          <div class="session-field-hint">You can manage session exports, attacker IPs, and summary settings after entering the workspace.</div>
          <div id="welcomeImportFeedback" style="display:none"></div>
        </div>
      </div>
    </div>
  </div>
</div>
