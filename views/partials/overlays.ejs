<div class="pw-overlay" id="evidenceFlagOverlay">
  <div class="pw-box" style="width:440px">
    <div class="pw-header">
      <span class="pw-header-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v18"/><path d="m5 4 12 3-4 5 4 5-12-3"/></svg>
      </span>
      <span class="pw-header-title">Add as Evidence</span>
      <button class="pw-header-close" onclick="cancelEvidenceFlagDialog()">&times;</button>
    </div>
    <div class="pw-body">
      <div class="pw-description">Review the selected note block, choose the evidence type, and add any supporting context before saving it to the session tracker.</div>
      <div class="pw-field">
        <label>Type</label>
        <select class="pw-input evidence-flag-select" id="evidenceFlagType" onkeydown="handleEvidenceFlagKey(event)">
          <option value="enumeration">Enumeration</option>
          <option value="initial_access">Initial Access</option>
          <option value="execution">Execution</option>
          <option value="persistence">Persistence</option>
          <option value="privilege_escalation">Privilege Escalation</option>
          <option value="credential_access">Credential Access</option>
          <option value="discovery">Discovery</option>
          <option value="lateral_movement">Lateral Movement</option>
          <option value="pivoting">Pivoting</option>
          <option value="collection">Collection</option>
          <option value="exfiltration">Exfiltration</option>
          <option value="cleanup">Cleanup</option>
          <option value="proof">Proof</option>
        </select>
      </div>
      <div class="pw-field">
        <label>Title</label>
        <input class="pw-input" id="evidenceFlagTitle" type="text" placeholder="Evidence title…" autocomplete="off" spellcheck="false" onkeydown="handleEvidenceFlagKey(event)">
      </div>
      <div class="pw-field">
        <label>Details</label>
        <textarea class="pw-input evidence-flag-textarea" id="evidenceFlagDetails" placeholder="Why it matters, what it proved, or any operator context…" spellcheck="false" onkeydown="handleEvidenceFlagKey(event)"></textarea>
      </div>
      <div class="pw-field">
        <label>Command / Block</label>
        <textarea class="pw-input evidence-flag-textarea evidence-flag-command" id="evidenceFlagCommand" placeholder="Selected command or proof block…" spellcheck="false" onkeydown="handleEvidenceFlagKey(event)"></textarea>
      </div>
      <div class="evidence-flag-toggle-row">
        <label class="evidence-flag-check">
          <input id="evidenceFlagAlsoLoot" type="checkbox" onchange="syncEvidenceFlagLootUi()">
          <span>Also add as Loot</span>
        </label>
      </div>
      <div class="evidence-flag-loot-fields" id="evidenceFlagLootFields" style="display:none">
        <div class="evidence-flag-loot-grid">
          <div class="pw-field">
            <label>Loot type</label>
            <select class="pw-input evidence-flag-select" id="evidenceFlagLootType" onchange="syncEvidenceFlagLootUi()" onkeydown="handleEvidenceFlagKey(event)">
              <option value="cleartext">Cleartext</option>
              <option value="hash">Hash</option>
              <option value="token">Token</option>
              <option value="key">Key</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="pw-field">
            <label>Target / Host</label>
            <input class="pw-input" id="evidenceFlagLootHost" type="text" placeholder="10.10.11.5 or DC01" autocomplete="off" spellcheck="false" onkeydown="handleEvidenceFlagKey(event)">
          </div>
        </div>
        <div class="pw-field">
          <label>Loot value</label>
          <textarea class="pw-input evidence-flag-textarea evidence-flag-loot-value" id="evidenceFlagLootValue" placeholder="Credential, hash, token, key, or flag…" spellcheck="false" onkeydown="handleEvidenceFlagKey(event)"></textarea>
        </div>
        <div class="pw-field">
          <label>Loot context</label>
          <input class="pw-input" id="evidenceFlagLootNote" type="text" placeholder="Optional context for the Loot tab…" autocomplete="off" spellcheck="false" onkeydown="handleEvidenceFlagKey(event)">
        </div>
        <div class="evidence-flag-loot-sync" id="evidenceFlagLootSyncWrap">
          <label class="evidence-flag-check">
            <input id="evidenceFlagLootSyncCredentials" type="checkbox">
            <span>Sync cleartext/hash into the Credentials note</span>
          </label>
        </div>
      </div>
      <div class="pw-actions">
        <button class="pw-btn secondary" onclick="cancelEvidenceFlagDialog()">Cancel</button>
        <button class="pw-btn primary" onclick="confirmEvidenceFlagDialog()">Add Evidence</button>
      </div>
    </div>
  </div>
</div>

<div class="evidence-selection-prompt" id="evidenceSelectionPrompt">
  <button class="evidence-selection-prompt-btn" onclick="flagPromptedSelectionAsEvidence()">
    <span aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v18"/><path d="m5 4 12 3-4 5 4 5-12-3"/></svg>
    </span>
    <span>Add as Evidence</span>
  </button>
</div>

