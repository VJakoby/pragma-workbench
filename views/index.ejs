<!DOCTYPE html>
<html class="bg-slate-950 text-slate-200">
<head>
    <title>CinderTrace Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #020617; font-family: 'Inter', sans-serif; }
        
        /* Tactical Markdown Styling */
        #md-view h1 { font-size: 1.8rem; font-weight: 900; color: #f97316; margin-bottom: 1rem; border-bottom: 1px solid #334155; }
        #md-view h2 { font-size: 1.4rem; font-weight: 700; color: #fb923c; margin-top: 1.5rem; margin-bottom: 0.5rem; }
        #md-view h3 { font-size: 1.1rem; font-weight: 600; color: #fdba74; margin-top: 1rem; }
        #md-view p { margin-bottom: 1rem; line-height: 1.6; color: #cbd5e1; }
        #md-view a { color: #38bdf8; text-decoration: underline; }
        
        /* Code Blocks & Copy Button */
        .code-container { position: relative; margin: 1rem 0; background: #000; border-radius: 4px; border: 1px solid #1e293b; }
        .code-container pre { padding: 1.25rem; margin: 0; overflow-x: auto; }
        .code-container code { font-family: 'ui-monospace', monospace; color: #e2e8f0; font-size: 0.85rem; }
        .copy-btn {
            position: absolute; top: 8px; right: 8px; background: #1e293b; color: #f97316; 
            border: 1px solid #334155; padding: 4px 8px; font-size: 10px; border-radius: 4px;
            cursor: pointer; text-transform: uppercase; font-weight: bold; transition: all 0.2s;
        }
        .copy-btn:hover { background: #334155; color: #fff; }

        /* Task List styling */
        .task-item { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; color: #cbd5e1; }
        .task-item input { accent-color: #f97316; width: 18px; height: 18px; cursor: pointer; }
    </style>
</head>
<body class="p-8">

    <header class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <h1 class="text-3xl font-black text-orange-500 tracking-tighter uppercase">CinderTrace</h1>
        <div class="relative w-full md:w-96">
            <input type="text" disabled placeholder="Search Dashboard... (Placeholder)" 
                   class="w-full bg-slate-900 border border-slate-800 rounded-lg px-4 py-2 text-sm text-slate-600 italic cursor-not-allowed">
        </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% services.forEach(svc => { %>
            <div onclick="loadTactical('<%= svc.ip %>', '<%= svc.port %>', '<%= svc.name %>', '<%= encodeURIComponent(svc.banner) %>')" 
                 class="bg-slate-900 border-2 <%= svc.hasMd ? 'border-orange-600' : 'border-slate-800' %> p-6 rounded-lg cursor-pointer hover:border-orange-400 transition-all shadow-xl group">
                <div class="flex justify-between items-start mb-4">
                    <span class="text-4xl font-black opacity-10 group-hover:opacity-30 transition-opacity"><%= svc.port %></span>
                    <span class="bg-slate-800 text-[10px] px-2 py-1 rounded text-orange-400 font-bold uppercase"><%= svc.name %></span>
                </div>
                <p class="text-xs text-slate-500 font-mono"><%= svc.ip %></p>
                <h3 class="font-bold text-white truncate"><%= svc.banner || 'No Banner Found' %></h3>
            </div>
        <% }) %>
    </div>

    <div id="modal" class="hidden fixed inset-0 bg-black/90 flex items-center justify-center p-12 z-50">
        <div class="bg-slate-900 w-full h-full rounded-xl border border-slate-700 flex flex-col overflow-hidden">
            
            <div class="p-6 border-b border-slate-800 flex justify-between items-center">
                <h2 id="modal-title" class="text-2xl font-black text-orange-500 tracking-tight"></h2>
                <button onclick="document.getElementById('modal').classList.add('hidden')" class="text-slate-400 hover:text-white text-3xl">&times;</button>
            </div>

            <div class="flex px-6 bg-slate-900/50 border-b border-slate-800">
                <button id="tab-tactical" onclick="switchTab('tactical')" class="px-6 py-3 text-xs font-bold border-b-2 border-orange-500 text-orange-500">TACTICAL VIEW</button>
                <button id="tab-search" onclick="switchTab('search')" class="px-6 py-3 text-xs font-bold border-b-2 border-transparent text-slate-500">INTEL SEARCH (PH)</button>
            </div>

            <div class="flex flex-1 overflow-hidden p-6 gap-6">
                <div id="view-tactical" class="flex w-full gap-6">
                    <div id="md-view" class="w-2/3 overflow-y-auto bg-slate-950 p-8 rounded-lg border border-slate-800"></div>
                    <div class="w-1/3 flex flex-col gap-4">
                        <h4 class="text-xs font-bold text-blue-500 uppercase">Indexer API Intel</h4>
                        <ul id="api-results" class="space-y-3"></ul>
                    </div>
                </div>

                <div id="view-search" class="hidden w-full flex flex-col items-center justify-center text-slate-600 border-2 border-dashed border-slate-800 rounded-lg">
                    <p class="italic uppercase tracking-widest text-sm">Global Intelligence Search Placeholder</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- CUSTOM MARKDOWN FUNCTION ---
        function simpleMarkdownToHTML(markdown) {
            let html = markdown;
            html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
            html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
            html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');
            html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            html = html.replace(/__(.*?)__/g, '<strong>$1</strong>');
            html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
            html = html.replace(/_(.*?)_/g, '<em>$1</em>');

            // Task List Logic
            html = html.replace(/- \[ \] (.*$)/gim, '<div class="task-item"><input type="checkbox"> $1</div>');
            html = html.replace(/- \[x\] (.*$)/gim, '<div class="task-item"><input type="checkbox" checked> $1</div>');

            // Code blocks with Copy Buttons
            html = html.replace(/```([\s\S]*?)```/g, (match, code) => {
                const escaped = code.trim().replace(/"/g, '&quot;').replace(/'/g, "\\'");
                return `<div class="code-container">
                            <button class="copy-btn" onclick="copyToClipboard('${escaped}', this)">Copy</button>
                            <pre><code>${code.trim()}</code></pre>
                        </div>`;
            });

            html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
            html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank">$1</a>');
            html = html.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>');
            html = '<p>' + html + '</p>';
            
            // Final Cleanup
            html = html.replace(/<p><\/p>/g, '').replace(/<p><h/g, '<h').replace(/<\/h([1-6])><\/p>/g, '</h$1>');
            html = html.replace(/<p><div class="(task-item|code-container)">/g, '<div class="$1">').replace(/<\/div><\/p>/g, '</div>');
            return html;
        }

        function copyToClipboard(text, btn) {
            const el = document.createElement('textarea');
            el.value = text.replace(/&quot;/g, '"');
            document.body.appendChild(el); el.select();
            document.execCommand('copy'); document.body.removeChild(el);
            const original = btn.innerText; btn.innerText = 'COPIED';
            setTimeout(() => { btn.innerText = original; }, 2000);
        }

        async function loadTactical(ip, port, name, encodedBanner) {
            const banner = decodeURIComponent(encodedBanner);
            document.getElementById('modal').classList.remove('hidden');
            document.getElementById('modal-title').innerText = `${ip}:${port} — ${name.toUpperCase()}`;
            document.getElementById('md-view').innerText = 'Loading...';
            
            try {
                const res = await fetch(`/tactical/${ip}/${port}/${name}/${encodeURIComponent(banner)}`);
                const data = await res.json();
                document.getElementById('md-view').innerHTML = simpleMarkdownToHTML(data.mdContent);
                
                const apiList = document.getElementById('api-results');
                apiList.innerHTML = data.indexerData.length > 0 
                    ? data.indexerData.map(item => `<li class="p-3 bg-slate-800 border-l-2 border-blue-500 rounded text-sm"><a href="${item.link}" target="_blank" class="text-blue-400 font-bold">${item.title}</a></li>`).join('')
                    : '<li class="text-slate-600 text-xs italic">No API results.</li>';
            } catch (e) { document.getElementById('md-view').innerText = 'Error loading tactical data.'; }
        }

        function switchTab(t) {
            const isTac = t === 'tactical';
            document.getElementById('view-tactical').classList.toggle('hidden', !isTac);
            document.getElementById('view-tactical').classList.toggle('flex', isTac);
            document.getElementById('view-search').classList.toggle('hidden', isTac);
            document.getElementById('tab-tactical').className = isTac ? 'px-6 py-3 text-xs font-bold border-b-2 border-orange-500 text-orange-500' : 'px-6 py-3 text-xs font-bold border-b-2 border-transparent text-slate-500';
            document.getElementById('tab-search').className = !isTac ? 'px-6 py-3 text-xs font-bold border-b-2 border-orange-500 text-orange-500' : 'px-6 py-3 text-xs font-bold border-b-2 border-transparent text-slate-500';
        }
    </script>
</body>
</html>