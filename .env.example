# Optional integrations
# Leave these disabled unless the external services exist and are reachable.
TOOLBOX_ENABLED=false
TOOLBOX_URL=http://127.0.0.1:3003
TOOLBOX_URLS=http://matrix:3003,http://host.docker.internal:3003,http://127.0.0.1:3003
ENGRAM_SEARCH_ENABLED=false
SEARCH_URL=http://engram:3002

# Local host user/group mapping for Docker volumes
PRAGMA_UID=1000
PRAGMA_GID=1000

# Persistent storage paths
PRAGMA_KB_PATH=./knowledge-base
PRAGMA_SESSIONS_PATH=./sessions

# Optional PDF export. Set false to skip Chromium in the Docker image.
PDF_EXPORT_ENABLED=false
